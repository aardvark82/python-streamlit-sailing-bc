# Place this file as helper-app/.env (NOT the project root).
# Same values as the main Streamlit app's .streamlit/secrets.toml — case-
# insensitive, quoted or unquoted, both work. Avoid inline `#` comments
# after values (Compose includes them as part of the value).

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_NAMESPACE_ID=
CLOUDFLARE_API_TOKEN=

# Optional — can also be set via Settings tab in the UI. Aliases recognized:
# OPENAI_API_KEY, OPENAI_KEY, OpenAI_key
OPENAI_API_KEY=
