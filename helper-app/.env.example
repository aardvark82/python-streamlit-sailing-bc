# Place this file as helper-app/.env (NOT the project root).
# Same values as the main Streamlit app's .streamlit/secrets.toml — case-
# insensitive, quoted or unquoted, both work. Avoid inline `#` comments
# after values (Compose includes them as part of the value).

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_NAMESPACE_ID=
CLOUDFLARE_API_TOKEN=

# Optional — can also be set via Settings tab in the UI. Aliases recognized:
# OPENAI_API_KEY, OPENAI_KEY, OpenAI_key
OPENAI_API_KEY=

# Local LLM (Ollama) — only needed if you switch AI provider to 'ollama'
# in Settings. Ollama runs as its OWN Coolify resource; this app reaches
# it over Coolify's predefined network. Set to the ollama container's
# network name + port. Find the exact name in Coolify → your Ollama
# resource → the service/container name. Example:
#   OLLAMA_URL=http://ollama:11434
# If your Ollama resource container is named differently, use that, e.g.
#   OLLAMA_URL=http://ollama-xyz123:11434
OLLAMA_URL=

